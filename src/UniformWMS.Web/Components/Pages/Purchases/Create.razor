@page "/purchases/create"
@attribute [Authorize]
@inject PurchaseOrderApiService PurchaseSvc
@inject UniformItemApiService UniformSvc
@inject SupplierApiService SupplierSvc
@inject NavigationManager Nav

<PageTitle>Tạo đơn nhập hàng - UniformWMS</PageTitle>
<PageHeader Title="Tạo đơn nhập hàng mới" Icon="bi-cart-plus">
    <Actions>
        <a href="/purchases" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </Actions>
</PageHeader>

<AlertMessage Message="@_error" Type="danger" />

<div class="row g-3">
    <!-- Header Info -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header fw-semibold bg-transparent">Thông tin đơn hàng</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">Nhà cung cấp <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="_supplierId">
                            <option value="">-- Chọn nhà cung cấp --</option>
                            @foreach (var s in _suppliers)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">Ngày đặt hàng</label>
                        <input type="date" class="form-control"
                               @bind="_orderDate" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">Ngày dự nhận</label>
                        <input type="date" class="form-control"
                               @bind="_expectedDate" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold small">Ghi chú</label>
                        <input type="text" class="form-control" placeholder="Ghi chú thêm..."
                               @bind="_description" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Lines -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between bg-transparent fw-semibold">
                <span>Chi tiết đơn hàng</span>
                <button class="btn btn-outline-primary btn-sm" @onclick="AddLine">
                    <i class="bi bi-plus-lg me-1"></i>Thêm dòng
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:30px;">#</th>
                                <th>Mặt hàng</th>
                                <th style="width:100px;">Số lượng</th>
                                <th style="width:150px;">Đơn giá (VNĐ)</th>
                                <th style="width:150px;" class="text-end">Thành tiền</th>
                                <th style="width:50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < _lines.Count; i++)
                            {
                                var idx = i;
                                var line = _lines[idx];
                                <tr>
                                    <td class="text-muted small">@(idx + 1)</td>
                                    <td>
                                        <select class="form-select form-select-sm" @bind="line.ItemId">
                                            <option value="">-- Chọn mặt hàng --</option>
                                            @foreach (var item in _items)
                                            {
                                                <option value="@item.Id">[@item.ItemCode] @item.Name (@item.SizeName/@item.Color)</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" min="1"
                                               @bind="line.Quantity" @bind:event="oninput" />
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" min="0"
                                               @bind="line.UnitPrice" @bind:event="oninput" />
                                    </td>
                                    <td class="text-end fw-semibold">
                                        @((line.Quantity * line.UnitPrice).ToString("N0"))đ
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => RemoveLine(idx)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!_lines.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">
                                    Chưa có dòng nào. Nhấn "Thêm dòng" để bắt đầu.
                                </td></tr>
                            }
                        </tbody>
                        @if (_lines.Any())
                        {
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="4" class="text-end fw-semibold">Tổng cộng:</td>
                                    <td class="text-end fw-bold text-primary fs-6">
                                        @(_lines.Sum(l => l.Quantity * l.UnitPrice).ToString("N0"))đ
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
            <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
                <a href="/purchases" class="btn btn-outline-secondary btn-sm">Hủy</a>
                <button class="btn btn-primary btn-sm" @onclick="HandleSubmit" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-lg me-1"></i>Tạo đơn hàng
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _saving;
    private string? _error;
    private Guid _supplierId;
    private DateTime _orderDate = DateTime.Today;
    private DateTime? _expectedDate;
    private string _description = "";
    private List<PurchaseLineItem> _lines = new();
    private List<SupplierDto> _suppliers = new();
    private List<UniformItemDto> _items = new();

    protected override async Task OnInitializedAsync()
    {
        var supRes = await SupplierSvc.GetPagedAsync(1, 200);
        _suppliers = supRes?.Items.Where(s => s.IsActive).ToList() ?? new();
        var itemRes = await UniformSvc.GetPagedAsync(1, 500);
        _items = itemRes?.Items.ToList() ?? new();
    }

    private void AddLine() => _lines.Add(new PurchaseLineItem { Quantity = 1 });
    private void RemoveLine(int idx) => _lines.RemoveAt(idx);

    private async Task HandleSubmit()
    {
        if (_supplierId == Guid.Empty) { _error = "Vui lòng chọn nhà cung cấp."; return; }
        if (!_lines.Any()) { _error = "Phải có ít nhất một dòng đơn hàng."; return; }
        if (_lines.Any(l => l.ItemId == Guid.Empty)) { _error = "Vui lòng chọn mặt hàng cho tất cả dòng."; return; }

        _saving = true; _error = null;
        var req = new
        {
            SupplierId = _supplierId,
            Description = _description,
            OrderDate = _orderDate,
            ExpectedDate = _expectedDate,
            Lines = _lines.Select(l => new { ItemId = l.ItemId, Quantity = l.Quantity, UnitPrice = l.UnitPrice })
        };
        var res = await PurchaseSvc.CreateAsync(req);
        if (res?.Success == true) Nav.NavigateTo("/purchases");
        else _error = res?.Errors.FirstOrDefault() ?? "Có lỗi xảy ra.";
        _saving = false;
    }

    private class PurchaseLineItem
    {
        public Guid ItemId { get; set; }
        public int Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; }
    }
}
