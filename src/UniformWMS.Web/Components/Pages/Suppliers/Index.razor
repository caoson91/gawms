@page "/suppliers"
@attribute [Authorize]
@inject SupplierApiService SupplierSvc

<PageTitle>Nhà cung cấp - UniformWMS</PageTitle>
<PageHeader Title="Nhà cung cấp" Subtitle="Danh sách nhà cung cấp" Icon="bi-building">
    <Actions>
        <a href="/suppliers/create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Thêm NCC
        </a>
    </Actions>
</PageHeader>

<AlertMessage Message="@_msg" Type="@_msgType" />

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="input-group input-group-sm" style="max-width:350px;">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Tìm theo mã hoặc tên..."
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <LoadingSpinner IsLoading="_loading" />
    @if (!_loading)
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã NCC</th><th>Tên nhà cung cấp</th><th>Người liên hệ</th>
                        <th>Điện thoại</th><th>Email</th><th>Mã số thuế</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width:90px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_result?.Items.Any() == true)
                    {
                        @foreach (var s in _result.Items)
                        {
                            <tr>
                                <td><code class="text-dark">@s.Code</code></td>
                                <td class="fw-semibold">@s.Name</td>
                                <td>@(s.ContactPerson ?? "—")</td>
                                <td>@(s.Phone ?? "—")</td>
                                <td>@(s.Email ?? "—")</td>
                                <td>@(s.TaxCode ?? "—")</td>
                                <td class="text-center">
                                    <span class="badge @(s.IsActive ? "bg-success bg-opacity-10 text-success" : "bg-secondary bg-opacity-10 text-secondary")">
                                        @(s.IsActive ? "Hoạt động" : "Ngừng")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a href="/suppliers/@s.Id/edit" class="btn btn-sm btn-outline-secondary" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" title="Xóa"
                                                @onclick="() => HandleDelete(s.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>Không có dữ liệu
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-transparent">
            <PaginationBar CurrentPage="_page" PageSize="20"
                           TotalCount="@(_result?.TotalCount ?? 0)"
                           OnPageChanged="LoadPage" />
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private PagedResult<SupplierDto>? _result;
    private int _page = 1;
    private string _search = "";
    private string? _msg; private string _msgType = "success";

    protected override async Task OnInitializedAsync() => await LoadPage(1);
    private async Task LoadPage(int p) { _loading = true; _page = p; _result = await SupplierSvc.GetPagedAsync(p, 20, _search); _loading = false; }
    private void OnSearch(KeyboardEventArgs e) { var t = new System.Timers.Timer(400); t.Elapsed += async (_, _) => { t.Dispose(); await InvokeAsync(() => LoadPage(1)); }; t.AutoReset = false; t.Start(); }

    private async Task HandleDelete(Guid id)
    {
        var res = await SupplierSvc.DeleteAsync(id);
        _msg = res?.Success == true ? "Xóa thành công." : res?.Errors.FirstOrDefault() ?? "Lỗi.";
        _msgType = res?.Success == true ? "success" : "danger";
        if (res?.Success == true) await LoadPage(_page);
    }
}
