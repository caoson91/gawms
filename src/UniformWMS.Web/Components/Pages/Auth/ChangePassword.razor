@page "/change-password"
@attribute [Authorize]
@inject AuthApiService AuthSvc
@inject NavigationManager Nav

<PageTitle>Đổi mật khẩu - UniformWMS</PageTitle>
<PageHeader Title="Đổi mật khẩu" Subtitle="Cập nhật mật khẩu tài khoản" Icon="bi-key">
    <Actions>
        <a href="/" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </Actions>
</PageHeader>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <AlertMessage Message="@_error" Type="danger" />
                <AlertMessage Message="@_success" Type="success" />

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" @bind="_current" autocomplete="current-password" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Mật khẩu mới <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" @bind="_newPwd" autocomplete="new-password" />
                    <div class="form-text">Tối thiểu 8 ký tự, có chữ hoa, chữ thường và số.</div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold small">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" @bind="_confirm" autocomplete="new-password" />
                </div>

                <button class="btn btn-primary w-100" @onclick="HandleSubmit" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-check-lg me-1"></i>Đổi mật khẩu
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string _current = "", _newPwd = "", _confirm = "";
    private bool _saving;
    private string? _error, _success;

    private async Task HandleSubmit()
    {
        _error = _success = null;
        if (string.IsNullOrWhiteSpace(_current) || string.IsNullOrWhiteSpace(_newPwd))
        {
            _error = "Vui lòng điền đầy đủ thông tin."; return;
        }
        if (_newPwd != _confirm) { _error = "Mật khẩu xác nhận không khớp."; return; }
        if (_newPwd.Length < 8) { _error = "Mật khẩu mới phải có ít nhất 8 ký tự."; return; }

        _saving = true;
        var ok = await AuthSvc.ChangePasswordAsync(new ChangePasswordRequest
        {
            CurrentPassword = _current,
            NewPassword = _newPwd,
            ConfirmPassword = _confirm
        });

        if (ok) { _success = "Đổi mật khẩu thành công! Vui lòng đăng nhập lại."; _current = _newPwd = _confirm = ""; }
        else { _error = "Mật khẩu hiện tại không đúng hoặc có lỗi xảy ra."; }
        _saving = false;
    }
}
