@page "/categories"
@attribute [Authorize]
@inject CategoryApiService CategorySvc

<PageTitle>Danh mục - UniformWMS</PageTitle>
<PageHeader Title="Danh mục đồng phục" Subtitle="Quản lý phân loại mặt hàng" Icon="bi-tags">
    <Actions>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg me-1"></i>Thêm danh mục
        </button>
    </Actions>
</PageHeader>

<AlertMessage Message="@_msg" Type="@_msgType" />

<LoadingSpinner IsLoading="_loading" />

@if (!_loading)
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:50px;">STT</th>
                        <th style="width:120px;">Mã</th>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>
                        <th class="text-center" style="width:100px;">Thứ tự</th>
                        <th class="text-center" style="width:110px;">Trạng thái</th>
                        <th class="text-center" style="width:100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_categories.Any())
                    {
                        int i = 1;
                        @foreach (var cat in _categories)
                        {
                            <tr>
                                <td class="text-muted small">@(i++)</td>
                                <td><code class="text-dark fw-semibold">@cat.Code</code></td>
                                <td class="fw-semibold">@cat.Name</td>
                                <td class="text-muted small">@(cat.Description ?? "—")</td>
                                <td class="text-center">@cat.DisplayOrder</td>
                                <td class="text-center">
                                    <span class="badge @(cat.IsActive ? "bg-success bg-opacity-10 text-success" : "bg-secondary bg-opacity-10 text-secondary")">
                                        @(cat.IsActive ? "Hoạt động" : "Ẩn")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <button class="btn btn-sm btn-outline-secondary" title="Sửa"
                                                @onclick="() => OpenEditModal(cat)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" title="Xóa"
                                                @onclick="() => ConfirmDelete(cat)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>Không có dữ liệu
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal -->
@if (_showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-semibold">
                        <i class="bi bi-tag me-2 text-primary"></i>
                        @(_editTarget == null ? "Thêm danh mục" : "Sửa danh mục")
                    </h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <AlertMessage Message="@_modalError" Type="danger" />
                    <div class="row g-3">
                        @if (_editTarget == null)
                        {
                            <div class="col-12">
                                <label class="form-label fw-semibold small">Mã danh mục <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="_cCode"
                                       placeholder="VD: AO, QUAN, GIAY..." />
                            </div>
                        }
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Tên danh mục <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_cName" placeholder="Nhập tên danh mục" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Mô tả</label>
                            <input type="text" class="form-control" @bind="_cDescription" placeholder="Mô tả ngắn..." />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Thứ tự hiển thị</label>
                            <input type="number" class="form-control" @bind="_cOrder" min="1" />
                        </div>
                        @if (_editTarget != null)
                        {
                            <div class="col-6">
                                <label class="form-label fw-semibold small">Trạng thái</label>
                                <select class="form-select" @bind="_cActive">
                                    <option value="true">Hoạt động</option>
                                    <option value="false">Ẩn</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseModal">Hủy</button>
                    <button class="btn btn-primary btn-sm" @onclick="SaveCategory" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg me-1"></i>Lưu
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<ConfirmDialog IsVisible="_showConfirm"
               Title="Xóa danh mục"
               Message="@($"Bạn có chắc muốn xóa danh mục '{_deleteTarget?.Name}'?")"
               ConfirmText="Xóa" ConfirmType="danger" ConfirmIcon="bi-trash"
               OnConfirm="ExecuteDelete"
               OnCancel="() => _showConfirm = false" />

@code {
    private bool _loading = true;
    private List<CategoryDto> _categories = new();
    private string? _msg; private string _msgType = "success";

    // Modal
    private bool _showModal, _saving;
    private string? _modalError;
    private CategoryDto? _editTarget;
    private string _cCode = "", _cName = "", _cDescription = "";
    private int _cOrder = 1;
    private bool _cActive = true;

    // Delete
    private bool _showConfirm;
    private CategoryDto? _deleteTarget;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        _categories = (await CategorySvc.GetAllAsync())?.ToList() ?? new();
        _loading = false;
    }

    private void OpenCreateModal()
    {
        _editTarget = null; _cCode = _cName = _cDescription = "";
        _cOrder = (_categories.Any() ? _categories.Max(c => c.DisplayOrder) + 1 : 1);
        _cActive = true; _modalError = null; _showModal = true;
    }

    private void OpenEditModal(CategoryDto cat)
    {
        _editTarget = cat; _cName = cat.Name; _cDescription = cat.Description ?? "";
        _cOrder = cat.DisplayOrder; _cActive = cat.IsActive;
        _modalError = null; _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(_cName)) { _modalError = "Tên danh mục không được để trống."; return; }
        _saving = true; _modalError = null;

        if (_editTarget == null)
        {
            if (string.IsNullOrWhiteSpace(_cCode)) { _modalError = "Mã danh mục không được để trống."; _saving = false; return; }
            var req = new CreateCategoryRequest { Code = _cCode.ToUpper(), Name = _cName, Description = _cDescription, DisplayOrder = _cOrder };
            var res = await CategorySvc.CreateAsync(req);
            if (res?.Success == true) { _msg = "Thêm danh mục thành công."; _msgType = "success"; _showModal = false; await LoadData(); }
            else _modalError = res?.Errors.FirstOrDefault() ?? "Lỗi.";
        }
        else
        {
            var req = new UpdateCategoryRequest { Name = _cName, Description = _cDescription, DisplayOrder = _cOrder, IsActive = _cActive };
            var res = await CategorySvc.UpdateAsync(_editTarget.Id, req);
            if (res?.Success == true) { _msg = "Cập nhật thành công."; _msgType = "success"; _showModal = false; await LoadData(); }
            else _modalError = res?.Errors.FirstOrDefault() ?? "Lỗi.";
        }
        _saving = false;
    }

    private void ConfirmDelete(CategoryDto cat) { _deleteTarget = cat; _showConfirm = true; }

    private async Task ExecuteDelete()
    {
        _showConfirm = false;
        if (_deleteTarget == null) return;
        var res = await CategorySvc.DeleteAsync(_deleteTarget.Id);
        _msg = res?.Success == true ? "Xóa danh mục thành công." : res?.Errors.FirstOrDefault() ?? "Lỗi.";
        _msgType = res?.Success == true ? "success" : "danger";
        if (res?.Success == true) await LoadData();
        _deleteTarget = null;
    }
}
