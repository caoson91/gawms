@page "/returns"
@attribute [Authorize]
@inject ReturnOrderApiService ReturnSvc

<PageTitle>Phiếu thu hồi - UniformWMS</PageTitle>
<PageHeader Title="Phiếu thu hồi" Subtitle="Quản lý thu hồi đồng phục" Icon="bi-box-arrow-in-down">
    <Actions>
        <a href="/returns/create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Tạo phiếu
        </a>
    </Actions>
</PageHeader>

<AlertMessage Message="@_msg" Type="@_msgType" />

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="input-group input-group-sm" style="max-width:350px;">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0 ps-0"
                   placeholder="Tìm theo mã phiếu..."
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <LoadingSpinner IsLoading="_loading" />
    @if (!_loading)
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã phiếu</th>
                        <th>Mô tả</th>
                        <th class="text-center">Số dòng</th>
                        <th class="text-center">Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Ngày thu hồi</th>
                        <th class="text-center" style="width:110px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_result?.Items.Any() == true)
                    {
                        @foreach (var order in _result.Items)
                        {
                            <tr>
                                <td><code class="fw-semibold">@order.OrderCode</code></td>
                                <td class="text-truncate" style="max-width:200px;">@(order.Description ?? "—")</td>
                                <td class="text-center">
                                    <span class="badge bg-info bg-opacity-10 text-info">@order.LineCount</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @ReturnStatusBadge(order.Status)">@order.StatusName</span>
                                </td>
                                <td class="small text-muted">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="small text-muted">@(order.ReturnedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a href="/returns/@order.Id" class="btn btn-sm btn-outline-primary" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (order.Status == 1)
                                        {
                                            <button class="btn btn-sm btn-outline-success" title="Duyệt"
                                                    @onclick="() => HandleApprove(order.Id)">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        }
                                        @if (order.Status == 2)
                                        {
                                            <button class="btn btn-sm btn-outline-info" title="Hoàn thành thu hồi"
                                                    @onclick="() => HandleComplete(order.Id)">
                                                <i class="bi bi-box-arrow-in-down"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>Chưa có phiếu thu hồi nào
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-transparent">
            <PaginationBar CurrentPage="_page" PageSize="20"
                           TotalCount="@(_result?.TotalCount ?? 0)"
                           OnPageChanged="LoadPage" />
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private PagedResult<ReturnOrderDto>? _result;
    private int _page = 1;
    private string _search = "";
    private string? _msg; private string _msgType = "success";

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int p)
    {
        _loading = true; _page = p;
        _result = await ReturnSvc.GetPagedAsync(p, 20, _search);
        _loading = false;
    }

    private void OnSearch(KeyboardEventArgs e)
    {
        var t = new System.Timers.Timer(400);
        t.Elapsed += async (_, _) => { t.Dispose(); await InvokeAsync(() => LoadPage(1)); };
        t.AutoReset = false; t.Start();
    }

    private async Task HandleApprove(Guid id)
    {
        var res = await ReturnSvc.ApproveAsync(id);
        _msg = res?.Success == true ? "Duyệt phiếu thành công." : res?.Errors.FirstOrDefault() ?? "Lỗi.";
        _msgType = res?.Success == true ? "success" : "danger";
        if (res?.Success == true) await LoadPage(_page);
    }

    private async Task HandleComplete(Guid id)
    {
        var res = await ReturnSvc.CompleteAsync(id);
        _msg = res?.Success == true ? "Thu hồi hoàn tất, đã cập nhật tồn kho." : res?.Errors.FirstOrDefault() ?? "Lỗi.";
        _msgType = res?.Success == true ? "success" : "danger";
        if (res?.Success == true) await LoadPage(_page);
    }

    private static string ReturnStatusBadge(int s) => s switch
    {
        1 => "bg-secondary",
        2 => "bg-warning text-dark",
        3 => "bg-success",
        4 => "bg-danger",
        _ => "bg-light text-dark"
    };
}
