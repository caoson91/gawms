@page "/issuances"
@attribute [Authorize]
@inject IssuanceOrderApiService IssuanceSvc

<PageTitle>Phiếu cấp phát - UniformWMS</PageTitle>

<PageHeader Title="Phiếu cấp phát" Subtitle="Quản lý cấp phát đồng phục" Icon="bi-box-arrow-up">
    <Actions>
        <a href="/issuances/create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Tạo phiếu
        </a>
    </Actions>
</PageHeader>

<AlertMessage Message="@_message" Type="@_msgType" />

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="input-group input-group-sm" style="max-width:350px;">
            <span class="input-group-text bg-light border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" class="form-control border-start-0 ps-0"
                   placeholder="Tìm theo mã phiếu..."
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <LoadingSpinner IsLoading="_loading" />
    @if (!_loading)
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã phiếu</th>
                        <th>Mô tả</th>
                        <th class="text-center">Số dòng</th>
                        <th class="text-center">Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Ngày duyệt</th>
                        <th>Ngày cấp phát</th>
                        <th class="text-center" style="width:90px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_result?.Items.Any() == true)
                    {
                        @foreach (var order in _result.Items)
                        {
                            <tr>
                                <td><code class="fw-semibold">@order.OrderCode</code></td>
                                <td class="text-truncate" style="max-width:180px;">@order.Description</td>
                                <td class="text-center">
                                    <span class="badge bg-primary bg-opacity-10 text-primary">@order.LineCount</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @StatusBadge(order.Status)">@order.StatusName</span>
                                </td>
                                <td class="small text-muted">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="small text-muted">@(order.ApprovedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td class="small text-muted">@(order.IssuedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a href="/issuances/@order.Id" class="btn btn-sm btn-outline-primary" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (order.Status == 1) // Draft
                                        {
                                            <button class="btn btn-sm btn-outline-success" title="Duyệt"
                                                    @onclick="() => HandleApprove(order.Id)">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" title="Hủy"
                                                    @onclick="() => HandleCancel(order.Id)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
                                Chưa có phiếu cấp phát nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-transparent">
            <PaginationBar CurrentPage="_page" PageSize="20"
                           TotalCount="@(_result?.TotalCount ?? 0)"
                           OnPageChanged="LoadPage" />
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private PagedResult<IssuanceOrderDto>? _result;
    private int _page = 1;
    private string _search = "";
    private string? _message;
    private string _msgType = "success";

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page)
    {
        _loading = true;
        _page = page;
        _result = await IssuanceSvc.GetPagedAsync(_page, 20, _search);
        _loading = false;
    }

    private void OnSearch(KeyboardEventArgs e)
    {
        var t = new System.Timers.Timer(400);
        t.Elapsed += async (_, _) => { t.Dispose(); await InvokeAsync(() => LoadPage(1)); };
        t.AutoReset = false; t.Start();
    }

    private async Task HandleApprove(Guid id)
    {
        var res = await IssuanceSvc.ApproveAsync(id);
        _message = res?.Success == true ? "Duyệt phiếu thành công." : res?.Errors.FirstOrDefault() ?? "Lỗi.";
        _msgType = res?.Success == true ? "success" : "danger";
        if (res?.Success == true) await LoadPage(_page);
    }

    private async Task HandleCancel(Guid id)
    {
        var res = await IssuanceSvc.CancelAsync(id);
        _message = res?.Success == true ? "Hủy phiếu thành công." : res?.Errors.FirstOrDefault() ?? "Lỗi.";
        _msgType = res?.Success == true ? "success" : "danger";
        if (res?.Success == true) await LoadPage(_page);
    }

    private static string StatusBadge(int status) => status switch
    {
        1 => "bg-secondary",
        2 => "bg-warning text-dark",
        3 => "bg-success",
        4 => "bg-danger",
        _ => "bg-light text-dark"
    };
}
