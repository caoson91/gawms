@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-@Type alert-dismissible d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi @IconClass flex-shrink-0"></i>
        <span>@Message</span>
        <button type="button" class="btn-close" @onclick="Dismiss"></button>
    </div>
}

@code {
    [Parameter] public string? Message { get; set; }
    [Parameter] public string Type { get; set; } = "info"; // success, danger, warning, info
    [Parameter] public EventCallback OnDismiss { get; set; }

    private string IconClass => Type switch
    {
        "success" => "bi-check-circle-fill",
        "danger"  => "bi-exclamation-triangle-fill",
        "warning" => "bi-exclamation-circle-fill",
        _         => "bi-info-circle-fill"
    };

    private async Task Dismiss()
    {
        Message = null;
        await OnDismiss.InvokeAsync();
    }
}
